{
	"name": "AknEditor",
	"namemsg": "aknedit-extensionname",
	"version": "0.1.0",
	"author": [
		"Dimitrys"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:AknEditor",
	"descriptionmsg": "aknedit-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"platform": {
			"php": ">= 8.1"
		},
		"extensions": {
			"AknRenderer": "*"
		}
	},
	"Actions": {
		"aknedit": "MediaWiki\\Extension\\AknEditor\\AknEditAction"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\AknEditor\\": "includes/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\AknEditor\\Tests\\Unit\\": "tests/phpunit/unit/"
	},
	"MessagesDirs": {
		"AknEditor": [
			"i18n"
		]
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "AknEditor/resources"
	},
	"ResourceModules": {
		"ext.aknEditor.app": {
			"scripts": [
				"ext.aknEditor.dom.js",
				"ext.aknEditor.fields.js",
				"ext.aknEditor.toolbar.js",
				"ext.aknEditor.dialogs.js",
				"ext.aknEditor.app.js",
				"ext.aknEditor.init.js"
			],
			"styles": "ext.aknEditor.styles.css",
			"dependencies": [
				"oojs-ui-core",
